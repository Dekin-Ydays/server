<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Notification</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333333;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .banner {
            width: 100%;
            margin-bottom: 20px;
        }
        .content {
            padding: 20px;
            background-color: #f9f9f9;
            border-radius: 5px;
        }
        .footer {
            margin-top: 20px;
            font-size: 12px;
            text-align: center;
            color: #888888;
        }
    </style>
</head>
<body>
<div class="container">
    <!-- Emplacement pour l'image de bannière -->
    <div class="banner">
        <img src="$bannerImageUrl" alt="Bannière" style="max-width: 100%; height: auto;">
    </div>

    <!-- Contenu de l'email avec placeholder pour le texte personnalisé -->
    <div class="content">
        <h2>Bonjour $name,</h2>

        <!-- Placeholder pour le texte personnalisé -->
        <div class="message">
            $message
        </div>

        <p>Cordialement,<br>L'équipe</p>
    </div>

    <div class="footer">
        <p>Cet email a été envoyé automatiquement. Merci de ne pas y répondre.</p>
        <p>&copy; $currentYear Tous droits réservés.</p>
    </div>
</div>
</body>
</html>